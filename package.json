{
  "name": "@amplitude/figma",
  "version": "5",
  "keywords": [
    "create-figma-plugin",
    "figma",
    "figma-plugin"
  ],
  "license": "MIT",
  "author": "Amplitude",
  "id": "921207224854227439",
  "dependencies": {
    "@create-figma-plugin/ui": "0.0.81",
    "@create-figma-plugin/utilities": "0.0.81",
    "amplitude-js": "^7.3.3",
    "axios": "^0.21.0",
    "preact": "^10.5.7",
    "querystring": "^0.2.0"
  },
  "devDependencies": {
    "@amplitude/eslint-config-typescript": "^1.1.0",
    "@create-figma-plugin/build": "0.0.81",
    "@create-figma-plugin/tsconfig": "0.0.81",
    "@figma/plugin-typings": "^1.125.0",
    "@types/amplitude-js": "^7.0.0",
    "@types/axios": "^0.14.0",
    "@typescript-eslint/eslint-plugin": "4",
    "eslint": "7",
    "eslint-config-preact": "^1.1.3",
    "eslint-config-standard-with-typescript": "^19.0.1",
    "eslint-plugin-import": "2",
    "eslint-plugin-node": "11",
    "eslint-plugin-promise": "4",
    "eslint-plugin-standard": "4",
    "husky": ">=4",
    "lint-staged": ">=10",
    "vitest": "^3.1.0"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--openssl-legacy-provider build-figma-plugin",
    "postbuild": "node -e \"const fs=require('fs');const m=JSON.parse(fs.readFileSync('manifest.json','utf8'));m.editorType=['figma'];fs.writeFileSync('manifest.json',JSON.stringify(m,null,2)+'\\n');\"",
    "watch": "NODE_OPTIONS=--openssl-legacy-provider build-figma-plugin --watch",
    "test": "vitest run",
    "lint": "eslint --cache --fix"
  },
  "figma-plugin": {
    "id": "921207224854227439",
    "name": "Amplitude Event Mapper",
    "editorType": [
      "figma"
    ],
    "menu": [
      {
        "name": "Overview",
        "main": "src/entries/overview.ts",
        "ui": "src/views/ui.tsx"
      },
      {
        "name": "All Events",
        "main": "src/entries/allEvents.ts",
        "ui": "src/views/ui.tsx"
      },
      {
        "name": "Import",
        "main": "src/entries/importEvents.ts",
        "ui": "src/views/ui.tsx"
      },
      {
        "name": "Create Event",
        "main": "src/entries/addEvent.ts",
        "ui": "src/views/ui.tsx"
      },
      {
        "name": "Tutorial",
        "main": "src/entries/tutorial.ts",
        "ui": "src/views/ui.tsx"
      }
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && yarn build"
    }
  },
  "lint-staged": {
    "*.ts": "yarn lint"
  }
}
